---
---
<div class="right-top"></div>

<script>
import { fetchSunriseSunset } from '../services/sunrise';

fetchSunriseSunset(48.407141, -114.334622)
  .then(result => {
    const el = document.querySelector('.right-top') as HTMLElement | null;
    if (!el) return;
    if (result) {
      el.textContent =
        'Sunrise:  ' + result.sunrise +
        '\nSunset:   ' + result.sunset +
        '\nDawn:     ' + result.dawn +
        '\nTwilight: ' + result.dusk;
    } else {
      el.textContent = 'Sunrise data unavailable';
    }
  })
  .catch(() => {
    const el = document.querySelector('.right-top') as HTMLElement | null;
    if (el) el.textContent = 'Sunrise data unavailable';
  });
</script>
